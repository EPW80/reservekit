# Server
PORT=3000
# Comma-separated list of browser origins allowed by CORS.
# Defaults to http://localhost:5173 when unset.
ALLOWED_ORIGINS=http://localhost:5173
# Set to "development" to surface error details/stack traces in API responses.
NODE_ENV=development

# Database
DATABASE_URL=postgres://user:password@localhost:5432/reservekit

# Auth
# Must be at least 32 characters and not the placeholder below — the API
# refuses to start otherwise. Generate one, e.g.: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=your_s3_bucket_name
