{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022"],
    "types": ["node"],

    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules", "client", "dist", "coverage"]
}
